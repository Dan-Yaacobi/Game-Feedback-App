NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/game_feedback
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_MIME=image/png,image/jpeg,image/webp

# SMTP settings for report email notifications.
# These values are required in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
OWNER_EMAIL=

CLIENT_ORIGIN=http://localhost:5173
